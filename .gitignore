.venv/

# Streamlit
.streamlit/secrets.toml

# Database
*.db
*.sqlite3

# Runtime-generated directories and files
output/
sessions/
uploads/
build/
history/

# Exceptions: pre-computed parquets the dashboard reads from on Streamlit Cloud.
# These contain processed payroll data — only acceptable in a PRIVATE repo.
!output/
!output/cache/
!output/cache/processed_data.parquet
!output/cache/income.parquet
!output/cache/standards.parquet
!output/cache/standards_audit.parquet
!output/cache/warnings.parquet
!output/cache/build_meta.json
!output/cache/_data_signatures.json
!output/master/
!output/master/master_full.parquet

# Generated master dataset
data/master_full.parquet
data/master.parquet

# Data files — real payroll PDFs and Excel sheets (private business data)
data/**/*.pdf
data/**/*.xlsx
data/**/*.xls
data/agreements.xlsx
data/employees_cost.xlsx
data/overrides.xlsx
# Keep folder structure but not content
!data/.gitkeep
!data/agreements/.gitkeep

# Temp / debug files
tmp*.json
*.log
*.tmp
*.bak
*.bak_*

# Claude Code local state (worktrees, settings)
.claude/worktrees/
.claude/settings.local.json

# Logs directory
logs/

